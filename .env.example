# Google Earth Engine
# Can use a service account key path if needed
EE_SERVICE_ACCOUNT_KEY_PATH=""

# Geocoding / Maps
# Used for Nominatim (User Agent is required) or Google Maps API
GEOCODING_USER_AGENT="goobta-ai-scraper"
GOOGLE_MAPS_API_KEY=""

# Data Paths
RAW_DATA_PATH="data/raw"
PROCESSED_DATA_PATH="data/processed"
MODELS_PATH="data/models"

# Scraping Configuration
SCRAPE_DELAY_SECONDS=2
MAX_PAGES_TO_SCRAPE=50
